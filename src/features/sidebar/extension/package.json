{
  "name": "pai",
  "displayName": "Pai",
  "description": "Pai 桌面版的连接器。",
  "version": "0.9.93",
  "publisher": "pai",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icons/128x128.png",
  "files": [
    "extension.js",
    "package.json",
    "dist/**",
    "icons/**"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "paiSidebar",
          "title": "Pai",
          "icon": "icons/32x32.png"
        }
      ]
    },
    "views": {
      "paiSidebar": [
        {
          "id": "paiSidebar.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "paiSidebar.refresh",
        "title": "Pai: 刷新连接器"
      }
    ]
  }
}
